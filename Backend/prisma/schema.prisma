generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
  VENDOR
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum ProductType {
  GOODS
  SERVICE
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum AttributeDisplayType {
  RADIO
  PILLS
  CHECKBOX
  IMAGE
}

enum RentalPeriodUnit {
  HOUR
  DAY
  NIGHT
  WEEK
  MONTH
}

enum DepositType {
  FIXED
  PERCENTAGE
}

enum LateFeeUnit {
  HOUR
  DAY
  WEEK
  MONTH
}

enum PriceRuleType {
  DISCOUNT
  FIXED_PRICE
}

enum ProductAssetStatus {
  AVAILABLE
  BOOKED
  PICKED_UP
  LATE_PICKUP
  LATE_RETURN
  MAINTENANCE
  RETIRED
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  role                Role                 @default(CUSTOMER)
  status              UserStatus           @default(ACTIVE)
  firstName           String
  lastName            String?
  phone               String?
  profileImage        String?
  companyName         String?
  productCategory     String?
  gstNumber           String?              @unique
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  createdProducts     Product[]            @relation("ProductCreatedBy")
  vendorProducts      Product[]            @relation("ProductVendor")

  @@index([role])
  @@index([status])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model RefreshToken {
  id                  String    @id @default(cuid())
  tokenHash           String    @unique
  userId              String
  expiresAt           DateTime
  revokedAt           DateTime?
  replacedByTokenHash String?
  createdAt           DateTime  @default(now())
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ProductCategory {
  id             String          @id @default(cuid())
  name           String          @unique
  slug           String          @unique
  description    String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  products       Product[]
  priceListRules PriceListRule[]

  @@index([isActive])
}

model Product {
  id             String                      @id @default(cuid())
  name           String
  slug           String                      @unique
  sku            String?                     @unique
  description    String?
  type           ProductType                 @default(GOODS)
  status         ProductStatus               @default(DRAFT)
  quantityOnHand Int                         @default(0)
  salesPrice     Decimal                     @db.Decimal(12, 2)
  costPrice      Decimal?                    @db.Decimal(12, 2)
  categoryId     String?
  createdById    String
  vendorId       String?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  category       ProductCategory?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy      User                        @relation("ProductCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  vendor         User?                       @relation("ProductVendor", fields: [vendorId], references: [id], onDelete: SetNull)
  images         ProductImage[]
  assets         ProductAsset[]
  attributeLinks ProductAttributeOnProduct[]
  variants       ProductVariant[]
  rentalConfig   ProductRentalConfig?
  priceListRules PriceListRule[]

  @@index([categoryId])
  @@index([createdById])
  @@index([vendorId])
  @@index([status])
  @@index([type])
  @@index([name])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  altText   String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([isPrimary])
}

model ProductAsset {
  id        String             @id @default(cuid())
  productId String
  variantId String?
  assetTag  String             @unique
  barcode   String?            @unique
  qrCode    String?            @unique
  status    ProductAssetStatus @default(AVAILABLE)
  notes     String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  product   Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant?    @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([variantId])
  @@index([status])
}

model ProductAttribute {
  id          String                      @id @default(cuid())
  name        String                      @unique
  slug        String                      @unique
  displayType AttributeDisplayType        @default(RADIO)
  isActive    Boolean                     @default(true)
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt
  values      ProductAttributeValue[]
  products    ProductAttributeOnProduct[]

  @@index([displayType])
  @@index([isActive])
}

model ProductAttributeValue {
  id            String                @id @default(cuid())
  attributeId   String
  value         String
  slug          String
  colorHex      String?
  imageUrl      String?
  sortOrder     Int                   @default(0)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  attribute     ProductAttribute      @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  variantValues ProductVariantValue[]

  @@unique([attributeId, value])
  @@unique([attributeId, slug])
  @@index([attributeId])
}

model ProductAttributeOnProduct {
  id          String           @id @default(cuid())
  productId   String
  attributeId String
  sortOrder   Int              @default(0)
  createdAt   DateTime         @default(now())
  product     Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute   ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([productId, attributeId])
  @@index([productId])
  @@index([attributeId])
}

model ProductVariant {
  id             String                @id @default(cuid())
  productId      String
  sku            String?               @unique
  name           String?
  quantityOnHand Int                   @default(0)
  salesPrice     Decimal?              @db.Decimal(12, 2)
  costPrice      Decimal?              @db.Decimal(12, 2)
  isActive       Boolean               @default(true)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  product        Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  values         ProductVariantValue[]
  assets         ProductAsset[]

  @@index([productId])
  @@index([isActive])
}

model ProductVariantValue {
  id               String                @id @default(cuid())
  variantId        String
  attributeValueId String
  variant          ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeValue   ProductAttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Restrict)

  @@unique([variantId, attributeValueId])
  @@index([attributeValueId])
}

model RentalPeriod {
  id             String                @id @default(cuid())
  name           String                @unique
  unit           RentalPeriodUnit
  duration       Int                   @default(1)
  isDefault      Boolean               @default(false)
  isActive       Boolean               @default(true)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  productConfigs ProductRentalConfig[]

  @@index([unit])
  @@index([isActive])
  @@index([isDefault])
}

model ProductRentalConfig {
  id                 String       @id @default(cuid())
  productId          String       @unique
  rentalPeriodId     String
  pickupTime         String?
  returnTime         String?
  paddingMinutes     Int          @default(0)
  depositType        DepositType  @default(FIXED)
  securityDeposit    Decimal      @default(0) @db.Decimal(12, 2)
  lateFeeUnit        LateFeeUnit  @default(HOUR)
  lateFee            Decimal      @default(0) @db.Decimal(12, 2)
  gracePeriodMinutes Int          @default(0)
  maxLateFee         Decimal?     @db.Decimal(12, 2)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  product            Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  rentalPeriod       RentalPeriod @relation(fields: [rentalPeriodId], references: [id], onDelete: Restrict)

  @@index([rentalPeriodId])
  @@index([depositType])
  @@index([lateFeeUnit])
}

model PriceList {
  id          String          @id @default(cuid())
  name        String          @unique
  description String?
  isDefault   Boolean         @default(false)
  isActive    Boolean         @default(true)
  validFrom   DateTime?
  validTo     DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  rules       PriceListRule[]

  @@index([isDefault])
  @@index([isActive])
  @@index([validFrom, validTo])
}

model PriceListRule {
  id              String           @id @default(cuid())
  priceListId     String
  productId       String?
  categoryId      String?
  ruleType        PriceRuleType
  discountPercent Decimal?         @db.Decimal(5, 2)
  fixedPrice      Decimal?         @db.Decimal(12, 2)
  minQuantity     Int              @default(1)
  validFrom       DateTime?
  validTo         DateTime?
  selectable      Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  priceList       PriceList        @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product         Product?         @relation(fields: [productId], references: [id], onDelete: Cascade)
  category        ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([priceListId])
  @@index([productId])
  @@index([categoryId])
  @@index([ruleType])
  @@index([selectable])
  @@index([validFrom, validTo])
}
