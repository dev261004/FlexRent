PORT=5000
NODE_ENV=development

# postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/rental_db"

# Use long random strings in real deployment (openssl rand -base64 48)
JWT_ACCESS_SECRET="replace-with-a-strong-secret"
JWT_REFRESH_SECRET="replace-with-a-different-strong-secret"

ACCESS_TOKEN_EXPIRY="15m"
REFRESH_TOKEN_EXPIRY="7d"
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=15

# Frontend URL, used for CORS
CLIENT_URL="http://localhost:3000"

# SMTP settings used by forgot password emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="smtp-user"
SMTP_PASS="smtp-password"
MAIL_FROM="FlexRent <no-reply@flexrent.local>"

