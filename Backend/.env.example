PORT=5000
NODE_ENV=development

# postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/rental_db"

# Use long random strings in real deployment (openssl rand -base64 48)
JWT_ACCESS_SECRET="replace-with-a-strong-secret"
JWT_REFRESH_SECRET="replace-with-a-different-strong-secret"

ACCESS_TOKEN_EXPIRY="15m"
REFRESH_TOKEN_EXPIRY="7d"

# Enables controlled ADMIN registration through POST /auth/register.
# Leave empty/undefined to disable public admin creation.
ADMIN_REGISTRATION_KEY="change-this-admin-registration-key"

# Used to enforce the hackathon requirement that passwords are unique
# without storing the raw password.
PASSWORD_FINGERPRINT_SECRET="replace-with-a-password-fingerprint-secret"

# Frontend URL, used for CORS
CLIENT_URL="http://localhost:3000"
